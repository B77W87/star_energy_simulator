        "        'R136a2':[53000,23.4],'R136a3':[53000,19.0],'イータカリーナA':[35000,60],'イータカリーナB':[37200,23.6],'プレイオネ':[12000,3.2],\n",
        "        'サンデュリーク-69°202':[18000,45],'ケプラー90':[6238,1.166],'プロキシマケンタウリ':[3042,0.1542],'バーナード星':[3134,0.2],\n",
        "        'ラランド21185':[3601,0.359],'ロス154':[3340,0.24],'カプタイン星':[3570,0.291],'ルイテン星':[3382,0.293],'ポラリス':[6000,50],\n",
        "        'ペガサス座51番星':[5793,1.266],'グリーゼ710':[4200,0.67],'はくちょう座P星':[19300,76],'おおいぬ座VY星':[2900,1420,],\n",
        "        'りょうけん座DG星':[3263,0.253],'とかげ座EV星':[3400,0.36],'ベガ':[9300,2.73],'シリウスB':[25200,0.0084],'プロキオンB':[9700,0.02],\n",
        "        'アルゴルB':[4500,3.48]}\n",
        "\n",
        "D=input('星の名前は?>>')\n",
        "if D not in mydict.keys():\n",
        "    T=float(input(str(D)+'の絶対温度(K)は?>>'))\n",
        "    R=float(input(str(D)+'の半径は太陽の何倍?>>'))\n",
        "    mydict[D]=[T,R]\n",
        "else:\n",
        "    T,R=mydict[D][0],mydict[D][1]\n",
        "\n",
        "p1 = 5.48 * 10 ** (-7)\n",
        "f1 = np.pi*(2.0*(6.62*10**(-34))*(3.0*10**8)**2/p1**5)*(1.0/(np.exp((6.62*10**(-34)*(3.0*10**8))/(p1*(1.38*10**(-23))*T))-1.0))\n",
        "f2 = np.pi*(2.0*(6.62*10**(-34))*(3.0*10**8)**2/p1**5)*(1.0/(np.exp((6.62*10**(-34)*(3.0*10**8))/(p1*(1.38*10**(-23))*5780))-1.0))\n",
        "B1 = f1 / f2 * R ** 2\n",
        "C1 = np.log(B1) / np.log(2.512)\n",
        "AM = 4.83 - C1\n",
        "\n",
        "def lad(xmin,xmax):\n",
        "    h=(xmax-xmin)/N\n",
        "    p=np.linspace(xmin,xmax,N+1)\n",
        "    f=np.pi*(2.0*(6.62*10**(-34))*(3.0*10**8)**2/p**5)*(1.0/(np.exp((6.62*10**(-34)*(3.0*10**8))/(p*(1.38*10**(-23))*T))-1.0))\n",
        "    S=(h/3)*(f[0]+f[N]+4.0*np.sum(f[1:N:2])+2.0*np.sum(f[2:N:2]))\n",
        "    F=np.pi*(2.0*(6.62*10**(-34))*(3.0*10**8)**2/p**5)*(1.0/(np.exp((6.62*10**(-34)*(3.0*10**8))/(p*(1.38*10**(-23))*5780))-1.0))\n",
        "    A=(h/3)*(F[0]+F[N]+4.0*np.sum(F[1:N:2])+2.0*np.sum(F[2:N:2]))\n",
        "    B=S/A\n",
        "    C=B*R**2\n",
        "    return C\n",
        "\n",
        "lad(1.0*10**(-8),1.0*10**(-3))\n",
        "print(str(D)+'の紫外線、可視光線、赤外線の総エネルギーは太陽の'+str(lad(1.0*10**(-8),1.0*10**(-3)))+'倍')\n",
        "lad(1.0*10**(-7),2.8*10**(-7))\n",
        "print(str(D)+'のUV-Cのエネルギーは太陽の'+str(lad(1.0*10**(-7),2.8*10**(-7)))+'倍')\n",
        "lad(1.0*10**(-8),3.8*10**(-7))\n",
        "print(str(D)+'の紫外線エネルギーは太陽の'+str(lad(1.0*10**(-8),3.8*10**(-7)))+'倍')\n",
        "lad(3.8*10**(-7),7.8*10**(-7))\n",
        "print(str(D)+'の可視光線エネルギーは太陽の'+str(lad(3.8*10**(-7),7.8*10**(-7)))+'倍')\n",
        "lad(7.8*10**(-7),1.0*10**(-3))\n",
        "print(str(D)+'の赤外線エネルギーは太陽の'+str(lad(7.8*10**(-7),1.0*10**(-3)))+'倍')\n",
        "print(str(D) + 'の絶対等級は' + str(AM) + '等です。')\n",
