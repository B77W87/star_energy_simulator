      ],
      "source": [
        "\n",
        "import numpy as np\n",
        "\n",
        "N=100000\n",
        "mydict={'ベテルギウス':[3600,764],'リゲル':[12100,78.9],'デネブ':[8500,108],'ナオス':[42000,11],'アルゴル':[13000,2.73],\n",
        "        'アルニタク':[29500,20.0],'アルニラム':[27000,42],'ミンタカ':[29500,16.5],'シリウス':[9940,1.71],'プロキオン':[6530,2.05],\n",
        "        'フォーマルハウト':[8590,1.84],'アルキオネ':[13000,10.0],'ベラトリックス':[21750,5.96],'R136a1':[53000,35.4],\n",
        "        'はくちょう座OB2-12':[13700,246],'カシオペヤ座ρ星':[7500,450],'カノープス':[7560,71],'アークトゥルス':[4290,25.4],\n",
